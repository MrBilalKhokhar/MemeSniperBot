# Copy this file to .env and fill in your values
# On Railway, set these as Environment Variables in the dashboard

# Your Solana wallet private key (base58 encoded)
# NEVER share this with anyone
PRIVATE_KEY=your_solana_private_key_here

# Your Solana RPC URL (get a free one from helius.dev or quicknode.com for better speed)
RPC_URL=https://api.mainnet-beta.solana.com

# DeepSeek API key (get from platform.deepseek.com)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Server port (Railway sets this automatically, leave as 3000 for local)
PORT=3000
